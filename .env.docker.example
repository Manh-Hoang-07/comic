# Copy this file to ".env.docker" and adjust values as needed.
#
# Run with:
#   docker compose --env-file .env.docker up --build

# APPLICATION CONFIGURATION
APP_NAME=NestJS Backend
NODE_ENV=production
PORT=8000
APP_VERSION=1.0.0
APP_URL=http://localhost:8000
GLOBAL_PREFIX=api
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000
APP_TIMEZONE=Asia/Ho_Chi_Minh

# DATABASE (Docker service name is "db")
DB_TYPE=mysql
DB_HOST=db
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=gioithieu
DB_CONNECTION_LIMIT=50

# IMPORTANT: set DATABASE_URL explicitly (do NOT use ${VAR} expansion)
DATABASE_URL=mysql://root:root@db:3306/gioithieu?connection_limit=50

# REDIS (Docker service name is "redis")
REDIS_URL=redis://redis:6379

# JWT CONFIGURATION (required)
JWT_SECRET=dev-secret-please-change-123456
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=dev-refresh-secret-please-change-123456
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=nestjs-backend
JWT_AUDIENCE=nestjs-frontend

# STORAGE (default local; change to s3 if you need)
STORAGE_TYPE=local
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_REGION=
STORAGE_S3_ENDPOINT=
STORAGE_S3_FORCE_PATH_STYLE=true
STORAGE_S3_BASE_URL=

# GOOGLE OAUTH (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/api/google/callback
GOOGLE_FRONTEND_URL=http://localhost:3000

# SECURITY
ENCRYPTION_KEY=your-32-character-secret-key-here
