NODE_ENV=production
PORT=8000
APP_VERSION=1.0.0
APP_URL=http://localhost:8000
GLOBAL_PREFIX=api
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3000
APP_TIMEZONE=Asia/Ho_Chi_Minh

